{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/main.py",
      "use": "@vercel/python",
      "config": { 
        "runtime": "python3.10",
        "includeFiles": "backend/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/api/main.py"
    }
  ],
  "env": {
    "PYTHONPATH": "backend"
  }
}
