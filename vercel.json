{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python",
      "config": { 
        "runtime": "python3.10",
        "includeFiles": "backend/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/main.py?path=/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/main.py?path=/$1"
    }
  ],
  "env": {
    "PYTHONPATH": "backend"
  }
}
